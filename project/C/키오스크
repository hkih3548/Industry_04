int page1() //아이디와 비밀번호
{
	char saveID[] = "qwer1";	//아이디
	char savePW[] = "qwer2";	//비밀번호
	char inputID[20];
	char inputPW[20];
	int count = 0;				//로그인 실패 횟수

	while (count < 3)
	{
		printf("아이디 : ");
		scanf("%19s", inputID);

		printf("비밀번호 : ");
		scanf("%19s", inputPW);


		if (strcmp(inputID, saveID) == 0 && strcmp(inputPW, savePW) == 0)
		{
			printf("\n로그인 되었습니다.\n");
			return 1;
		}
		count++;
		printf("\n로그인 실패(누적 %d회)\n", count);
		printf("\n");

	}
	printf("\n3회 로그인 실패했습니다.\n");
	return 0;

}
