from pop import Oled, delay
oled = Oled()
oled.init()
(x, y) = (0, 0) # 시작위치
oled.setTextSize(s=1) #글자크기
while True:
    if x > 120 and y >64:
        x = y = 0 # 50을 넘어가면 원상태로 위치
    oled.setCursor(x, y)
    oled.print("ki ho") # 영문 이름
    oled.clearDisplay() # 화면을 지워주세요
    (x, y) = (x + 1, y +1)
