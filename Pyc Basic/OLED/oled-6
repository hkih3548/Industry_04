from pop import Oled, delay, Sht20
oled = Oled(automode=True)
oled.init()
sht = Sht20()
oled.setTextSize(s=1)
oled.clearDisplay()
while True:
    temp, humid = sht.readTemp(), sht.readHumi()
    temp = round(temp,2)
    humid = round(humid, 2)
    temp = str(temp)
    humid = str(humid)
    oled.clearDisplay()
    oled.setCursor(10,10)
    oled.print("Temperature: ")
    oled.print(temp)
    oled.print("\n")
    oled.setCursor(10,20)
    oled.print("Humidity: ")
    oled.print(humid)
    oled.print("\n")
    oled.display()
    delay(500)
