from pop import Switches, Leds

switch = Switches() # 클래스 생성자
led = Leds() # 클래스 생성자
while True:
    btn_state1 = switch[0].read()
    btn_state2 = switch[1].read()
    if not btn_state1:
        for i in [0,2,4,6]:
            led[i].on()
        for i in [1,3,5,7]:
            led[i].off()
    if not btn_state2:
        for i in [0,2,4,6]:
            led[i].off()
        for i in [1,3,5,7]:
            led[i].on()
    else:
        led.allOff()
